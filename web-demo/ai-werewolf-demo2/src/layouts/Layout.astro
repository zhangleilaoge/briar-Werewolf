---
interface Props {
  title?: string;
}

const { title = '狼人杀 AI Demo' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="bg-slate-900 text-slate-200 min-h-screen">
    <slot />
  </body>
</html>
