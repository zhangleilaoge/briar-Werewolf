---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="狼人杀 AI 系统">
  <div class="min-h-screen bg-slate-900 text-slate-200 p-6">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-2xl font-bold text-amber-400 mb-2">🐺 狼人杀 AI 系统</h1>
      <p class="text-sm text-slate-400 mb-6">记忆 → 推理 → 关系 → 意图 → 行动</p>
      
      <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
        <p class="text-slate-300">正在加载游戏引擎...</p>
        <p class="text-sm text-slate-500 mt-2">如果未自动跳转，请刷新页面。</p>
      </div>
    </div>
  </div>

  <script>
    window.location.href = '/demo';
  </script>
</Layout>
